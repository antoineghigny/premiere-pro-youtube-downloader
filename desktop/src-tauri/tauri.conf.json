{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT2Premiere",
  "version": "3.0.0",
  "identifier": "com.yt2premiere.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YT2Premiere",
        "width": 1480,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg"],
    "icon": ["icons/icon.ico"]
  }
}
